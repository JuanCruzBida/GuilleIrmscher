{
  "theme": {
    "colors": {
      "base": {
        "background": "oklch(0.15 0.02 250)",
        "foreground": "oklch(0.98 0 0)"
      },
      "accent": {
        "primary": "oklch(0.85 0.21 95)",
        "hover": "oklch(0.88 0.24 90)"
      },
      "text": {
        "contrast": "oklch(0.98 0 0)",
        "muted": "oklch(0.60 0.02 250)"
      }
    },
    "spacing": {
      "scale": "modular",
      "base": "0.25rem",
      "ratio": 1.5,
      "tokens": {
        "xs": "calc(0.25rem * 1)",
        "sm": "calc(0.25rem * 2)",
        "md": "calc(0.25rem * 4)",
        "lg": "calc(0.25rem * 8)",
        "xl": "calc(0.25rem * 16)",
        "2xl": "calc(0.25rem * 32)"
      }
    },
    "typography": {
      "fontFamily": {
        "sans": ["Outfit", "Inter", "system-ui", "sans-serif"],
        "display": ["Inter", "sans-serif"]
      },
      "fontSize": {
        "display": "clamp(3rem, 10vw, 8rem)",
        "h1": "clamp(2rem, 5vw, 4rem)",
        "h2": "clamp(1.5rem, 4vw, 3rem)",
        "h3": "clamp(1.25rem, 3vw, 2rem)",
        "body": "1rem"
      }
    }
  }
}
